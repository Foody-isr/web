NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080
NEXT_PUBLIC_API_TOKEN= # optional dev JWT token (Bearer) from foodyserver login for staff APIs

# Currency Configuration (ILS for Israel, USD, EUR, etc.)
# NEXT_PUBLIC_CURRENCY=ILS

# Dev-only: show "Skip OTP" button on checkout (never enable in production)
# NEXT_PUBLIC_SKIP_OTP_ENABLED=true
